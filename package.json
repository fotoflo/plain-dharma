{
  "name": "plain-dharma",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash -c 'if [ \"$NGROK\" = \"1\" ]; then ./scripts/shell/ngrok-dev.sh 8008 & fi && next dev -p 8008'",
    "dev:tunnel": "bash -c 'NGROK=1 pnpm dev'",
    "ngrok": "./scripts/shell/ngrok-dev.sh",
    "ngrok:status": "./scripts/shell/ngrok-status.sh",
    "ngrok:qr": "./scripts/shell/ngrok-qr.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate-illustrations": "node --env-file=.env.local --import tsx scripts/generate-illustrations.ts",
    "generate-audio": "node --env-file=.env.local --import tsx scripts/generate-audio.ts",
    "transparentize-illustrations": "tsx scripts/transparentize-illustrations.ts",
    "build-ebook": "tsx scripts/build-ebook.ts",
    "build-pdf": "tsx scripts/build-pdf.ts",
    "build-print-pdf": "tsx scripts/build-print-pdf.ts",
    "build-audiobook": "tsx scripts/build-audiobook.ts",
    "generate-cover": "node --env-file=.env.local --import tsx scripts/generate-cover.ts",
    "publish-downloads": "tsx scripts/publish-downloads.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "@stripe/stripe-js": "^9.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mdx": "^2.0.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "shadcn": "^4.8.0",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "ngrok": "5.0.0-beta.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
