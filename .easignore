# .easignore — files EAS Build should NOT upload.
#
# IMPORTANT: .easignore REPLACES .gitignore for the build archive (EAS does
# not read .gitignore when this file exists). So this must re-list every
# ignore pattern — keep it in sync with ./.gitignore and apps/mobile/.gitignore.
# Bare patterns (no leading slash) match at any depth, so they cover the
# mobile workspace too.

# ── dependencies ──
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── build output / caches ──
.next/
out/
build/
dist/
web-build/
coverage/
.expo/
.metro-health-check*
*.tsbuildinfo
next-env.d.ts
expo-env.d.ts

# ── env & signing secrets ──
.env*
!.env.example
*.pem
*.p8
AuthKey_*.p8
*.p12
*.key
*.jks
*.mobileprovision

# ── editor / OS ──
.DS_Store
.idea/
.vscode/

# ── logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── tooling ──
.vercel/
.vercel
/tmp/ngrok.log
.tmp-fonts/
.claude/worktrees/

# ── generated native dirs (CNG regenerates these on EAS) ──
apps/mobile/ios/
apps/mobile/android/

# ───────────────────────────────────────────────────────────────────────────
# EAS-only extras: heavy, web-only content the iOS/Android build never uses.
# The mobile app bundles apps/mobile/assets and reads suttas from
# packages/content; it streams audio from plaindharma.com at runtime — so
# none of public/ is needed. Excluding these + .git drops the upload archive
# from ~439 MB to a few MB.
# ───────────────────────────────────────────────────────────────────────────
.git/
public/
combined-suttas.md
docs/
supabase/
